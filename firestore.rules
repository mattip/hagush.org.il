rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ── Utility Helper methods ──────────────────────────────────────

    function authed()  { return request.auth != null; }
    function email()   { return request.auth.token.email; }
    // roles/{email} doc ids are stored lowercase, but OAuth tokens can carry mixed
    // case (e.g. Naomibeyth@gmail.com). Normalise before the exact-match lookup,
    // otherwise the role doc isn't found and every role-gated write is denied.
    function emailKey() { return request.auth.token.email.lower(); }
    function roleDoc() { return get(/databases/$(database)/documents/roles/$(emailKey())).data; }
    function hasRole() {
      return authed()
        && exists(/databases/$(database)/documents/roles/$(emailKey()))
        && roleDoc().active == true;
    }
    function isAdmin()         { return hasRole() && roleDoc().role == 'admin'; }
    function isEventAdder()    { return hasRole() && roleDoc().role == 'event_adder'; }
    function canManageEvents() { return isAdmin() || isEventAdder(); }
    function isAskAdmin() { return hasRole() && roleDoc().role == 'ask_admin'; }
    function canManageInterviews() { return isAdmin() || isAskAdmin(); }
    function mgrFull()         { return hasRole() && roleDoc().role == 'manager' && roleDoc().scope == 'full'; }
    function mgrGroup()        { return hasRole() && roleDoc().role == 'manager' && roleDoc().scope == 'group'; }
    function isReferrer()      { return hasRole() && roleDoc().role in ['referrer', 'groupLeader']; }
    function validStr(val, max) { return val is string && val.size() <= max; }
    // Optional string: valid when absent, or a string within the length limit.
    function optStr(data, key, max) { return !(key in data) || validStr(data[key], max); }

    function canReadScoped(res) {
      return isAdmin() || mgrFull()
        || (mgrGroup()    && res.data.groupId    == roleDoc().groupId)
        || (isReferrer()  && res.data.referrerId == roleDoc().referrerId);
    }

    // ── PII / audit (server-only writes) ──────────────────────────────────────
    match /registrations/{id} {
      allow read:           if canReadScoped(resource);
      allow create, delete: if false;
      allow update:         if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['clean','test','duplicate','suspicious'];
    }
    match /questions/{id}    { allow read: if isAdmin() || mgrFull(); allow write: if false; }

    // ── join form (anonymous create, PII, admin-read) ─────────────────────────
    function validJoinFields() {
      return validStr(request.resource.data.firstName, 100)
        && validStr(request.resource.data.lastName,  100)
        && validStr(request.resource.data.phone,      30)
        && optStr(request.resource.data, 'email',    254)
        && validStr(request.resource.data.city,      100)
        && optStr(request.resource.data, 'idNumber',  20)
        && validStr(request.resource.data.source,    256)
        && validStr(request.resource.data.referrer,  256)
        && (request.resource.data.registered is bool || request.resource.data.registered is string);
    }
    function validImportDoc() {
      return request.resource.data.ts is timestamp
        && request.resource.data.keys().hasOnly(
          ['ts','firstName','lastName','phone','email','city','idNumber','registered','referrer','source','importBatchId','importedAt'])
        && validStr(request.resource.data.importBatchId, 64)
        && request.resource.data.importedAt is timestamp
        && validJoinFields();
    }
    match /join_form/{id} {
      // Anonymous public submission from the join form.
      allow create: if request.resource.data.ts is timestamp
        && request.resource.data.keys().hasOnly(
          ['ts','firstName','lastName','phone','email','city','idNumber','registered','referrer','source'])
        && validJoinFields();
      // Admin CSV import: same fields plus import audit metadata.
      allow create: if isAdmin() && validImportDoc();
      allow read:   if isAdmin();
      // Re-import with deterministic ids overwrites existing import records, but
      // never an organic public submission (which has no importBatchId).
      allow update: if isAdmin()
        && resource.data.importBatchId is string
        && validImportDoc();
      // Admins may revert an import by deleting only records tagged with a batch id.
      allow delete: if isAdmin() && resource.data.importBatchId is string;
    }
    match /ask_candidate_form/{id} { allow read: if isAdmin(); allow write: if false; }

    // ── login audit ───────────────────────────────────────────────────────────
    match /login_events/{id} {
      allow read:   if isAdmin();
      allow create: if authed()
        && request.resource.data.email == email()
        && request.resource.data.ts is timestamp
        && request.resource.data.status in ['success', 'forbidden']
        && request.resource.data.keys().hasOnly(['email', 'status', 'ts']);
      allow update, delete: if false;
    }

    // ── client error log (diagnostics) ────────────────────────────────────────
    // Any signed-in user may append a failure record — deliberately NOT gated on
    // a role, so writes that were denied for lack of a role can still be logged.
    // Captures the exact token email/casing the rules saw. Admin-read only.
    match /client_errors/{id} {
      allow read:   if isAdmin();
      allow create: if authed()
        && request.resource.data.ts is timestamp
        && request.resource.data.keys().hasOnly(['email','uid','op','code','message','page','ts'])
        && optStr(request.resource.data, 'email',   254)
        && optStr(request.resource.data, 'uid',     128)
        && optStr(request.resource.data, 'op',      100)
        && optStr(request.resource.data, 'code',    100)
        && optStr(request.resource.data, 'message', 500)
        && optStr(request.resource.data, 'page',    100);
      allow update, delete: if false;
    }

    // ── events and interviews ─────────────────────────────────────────────────
    match /campaign_events/{id} {
      allow read: if true;
      allow create: if canManageEvents();
      allow update, delete: if isAdmin()
        || (canManageEvents()
            && get(/databases/$(database)/documents/campaign_event_owner/$(id)).data.email == email());
    }

    match /campaign_event_owner/{id} {
      allow read: if isAdmin() || (canManageEvents() && resource.data.email == email());
      allow create: if canManageEvents() && request.resource.data.email == email();
      allow update, delete: if false;
    }

    match /interviews/{id} {
      allow read: if true;
      allow create, update, delete: if canManageInterviews();
    }
    
    match /interview_content/{id} {
      allow read: if true;
  		allow create, update, delete: if canManageInterviews();
		}

		match /parsing_config/{id} {
  		allow read, write: if canManageInterviews();
		}

    // ── referrer dimension (non-PII metadata) ────────────────────────────────
    // All authenticated dashboard users can read; only admins can write.
    match /referrers/{code} {
      allow read:  if hasRole();
      allow delete: if isAdmin();
      allow write: if isAdmin()
        && validStr(request.resource.data.name, 200)
        && request.resource.data.active is bool
        && request.resource.data.type in ['individual', 'organizer']
        && (request.resource.data.groupId == null || validStr(request.resource.data.groupId, 100));
    }
    match /referrer_groups/{groupId} {
      allow read:  if hasRole();
      allow delete: if isAdmin();
      allow write: if isAdmin()
        && validStr(request.resource.data.name, 200)
        && request.resource.data.active is bool;
    }

    // ── management ────────────────────────────────────────────────────────────
    match /roles/{userEmail} {
      allow read:  if isAdmin() || (authed() && email() == userEmail);
      allow write: if isAdmin();
    }

    match /{document=**} { allow read, write: if false; }
  }
}
